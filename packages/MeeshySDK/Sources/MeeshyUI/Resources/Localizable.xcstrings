    "voiceProfile.consent.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice cloning"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stimmklonen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clonación vocal"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Clonagem vocal"
          }
        }
      }
    },
    "voiceProfile.consent.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy can clone your voice to translate your audio messages in other languages with your own voice."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy kann Ihre Stimme klonen, um Ihre Audionachrichten in anderen Sprachen mit Ihrer Stimme zu übersetzen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy puede clonar tu voz para traducir tus mensajes de audio en otros idiomas con tu propia voz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Meeshy pode clonar sua voz para traduzir suas mensagens de áudio em outros idiomas com sua própria voz."
          }
        }
      }
    },
    "voiceProfile.consent.point1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record a few samples of your voice"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nehmen Sie einige Stimmproben auf"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Graba algunas muestras de tu voz"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Grave algumas amostras da sua voz"
          }
        }
      }
    },
    "voiceProfile.consent.point2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A unique voice model is created from your samples"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein einzigartiges Stimmmodell wird aus Ihren Proben erstellt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se crea un modelo de voz único a partir de tus muestras"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um modelo de voz único é criado a partir das suas amostras"
          }
        }
      }
    },
    "voiceProfile.consent.point3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your audio translations will use your cloned voice"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Audioübersetzungen verwenden Ihre geklonte Stimme"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus traducciones de audio usarán tu voz clonada"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas traduções de áudio usarão sua voz clonada"
          }
        }
      }
    },
    "voiceProfile.consent.point4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can delete your voice data at any time (GDPR)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können Ihre Stimmdaten jederzeit löschen (DSGVO)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes eliminar tus datos vocales en cualquier momento (RGPD)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode excluir seus dados vocais a qualquer momento (RGPD)"
          }
        }
      }
    },
    "voiceProfile.consent.point5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your samples are encrypted and never shared"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Proben sind verschlüsselt und werden nie geteilt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus muestras están encriptadas y nunca se comparten"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas amostras são criptografadas e nunca compartilhadas"
          }
        }
      }
    },
    "voiceProfile.consent.toggle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I agree that my voice samples will be used to create a voice profile"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich stimme zu, dass meine Stimmproben zur Erstellung eines Stimmprofils verwendet werden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acepto que mis muestras vocales se utilicen para crear un perfil vocal"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceito que minhas amostras vocais sejam usadas para criar um perfil vocal"
          }
        }
      }
