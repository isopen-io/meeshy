{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": ".",
  "transformIgnorePatterns": [
    "node_modules/(?!@meeshy/shared)"
  ],
  "moduleNameMapper": {
    "^@meeshy/shared$": "<rootDir>/../../packages/shared/types/index.ts",
    "^@meeshy/shared/prisma/client$": "<rootDir>/src/__tests__/__stubs__/prisma-client.ts",
    "^@meeshy/shared/(.*)$": "<rootDir>/../../packages/shared/$1",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "testMatch": [
    "<rootDir>/src/**/__tests__/**/*.test.ts",
    "<rootDir>/src/**/*.test.ts"
  ],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "<rootDir>/src/__tests__/e2ee/",
    "<rootDir>/src/__tests__/integration/",
    "<rootDir>/src/__tests__/resilience/",
    "<rootDir>/src/__tests__/performance/",
    "<rootDir>/src/__tests__/notifications-",
    "<rootDir>/src/__tests__/NotificationService",
    "<rootDir>/src/__tests__/password-reset",
    "<rootDir>/src/__tests__/unit/StatusService",
    "<rootDir>/src/__tests__/unit/MaintenanceService",
    "<rootDir>/src/__tests__/unit/encryption/shared-encryption",
    "<rootDir>/src/dma-interoperability/"
  ],
  "collectCoverageFrom": [
    "src/services/**/*.ts",
    "src/routes/**/*.ts",
    "src/middleware/**/*.ts",
    "src/socketio/**/*.ts",
    "src/utils/**/*.ts",
    "src/jobs/**/*.ts",
    "src/validation/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/__tests__/**",
    "!src/main.ts",
    "!src/server.ts"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": [
    "text",
    "lcov",
    "html"
  ],
  "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": "tsconfig.test.json",
      "diagnostics": {
        "ignoreCodes": [2307, 2322, 2339, 2345, 2740]
      }
    }]
  },
  "moduleFileExtensions": ["ts", "js", "json"],
  "coverageThreshold": {
    "global": {
      "lines": 87,
      "branches": 80,
      "statements": 86,
      "functions": 83
    }
  }
}
