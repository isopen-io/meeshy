{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@meeshy/shared": ["../../packages/shared/dist/types/index.d.ts", "./packages/shared/dist/types/index.d.ts"],
      "@meeshy/shared/prisma/client": ["../../packages/shared/prisma/client", "./packages/shared/prisma/client", "./src/__mocks__/prisma-client"],
      "@meeshy/shared/*": ["../../packages/shared/dist/*", "../../packages/shared/*", "./packages/shared/dist/*", "./packages/shared/*"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/agent/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
