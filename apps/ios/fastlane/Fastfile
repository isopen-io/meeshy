# Fastfile for Meeshy iOS
# Uses App Store Connect API Key for all operations (no Apple ID needed)

default_platform(:ios)

platform :ios do
  # ========================================
  # API KEY HELPER
  # ========================================

  def api_key
    @api_key ||= app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"] || "5542B6LVNL",
      issuer_id: ENV["ASC_ISSUER_ID"] || "69a6de89-ae7a-47e3-e053-5b8c7c11a4d1",
      key_content: ENV["ASC_KEY_CONTENT"],       # Base64 .p8 content (CI)
      key_filepath: ENV["ASC_KEY_FILEPATH"],      # OR path to .p8 file (local dev)
      in_house: false,
      is_key_content_base64: ENV["ASC_KEY_CONTENT"] ? true : false
    )
  end

  # ========================================
  # BEFORE ALL
  # ========================================
  before_all do
    ensure_git_status_clean unless ENV['CI'] || ENV['SKIP_GIT_CHECK']
  end

  # ========================================
  # TESTING
  # ========================================

  desc "Run unit tests"
  lane :test do
    scan(
      project: "Meeshy.xcodeproj",
      scheme: "Meeshy",
      configuration: "Debug",
      devices: ["iPhone 16 Pro"],
      code_coverage: true,
      output_directory: "./fastlane/test_output",
      output_types: "html,junit",
      clean: true
    )
  end

  # ========================================
  # CODE SIGNING (Match + API Key)
  # ========================================

  desc "Sync certificates and provisioning profiles"
  lane :sync_certificates do
    match(
      type: "appstore",
      app_identifier: [
        "me.meeshy.app",
        "me.meeshy.app.notification-service",
        "me.meeshy.app.widgets"
      ],
      api_key: api_key,
      readonly: is_ci,
      force_legacy_encryption: true
    )
  end

  desc "Sync development certificates"
  lane :sync_dev_certificates do
    match(
      type: "development",
      app_identifier: "me.meeshy.app",
      api_key: api_key,
      readonly: is_ci
    )
  end

  # ========================================
  # BUILD
  # ========================================

  desc "Build production IPA"
  lane :build_production do
    build_app(
      project: "Meeshy.xcodeproj",
      scheme: "Meeshy",
      configuration: "Release",
      output_directory: "./build",
      output_name: "Meeshy.ipa",
      derived_data_path: "./Build",
      clean: false,
      cloned_source_packages_path: "./SourcePackages",
      export_options: "./fastlane/ExportOptions.plist",
      xcargs: "DEVELOPMENT_TEAM=D72UK7R5RE -allowProvisioningUpdates SWIFT_OPTIMIZATION_LEVEL=-Onone CODE_SIGN_STYLE=Automatic"
    )
  end

  # ========================================
  # DEPLOY: TESTFLIGHT
  # ========================================

  desc "Build + upload to TestFlight"
  lane :beta do |options|
    sync_certificates

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1
    )

    test unless options[:skip_tests]

    build_production

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: options[:changelog] || "Bug fixes and improvements"
    )

    UI.success("Build uploaded to TestFlight!")
  end

  # ========================================
  # DEPLOY: APP STORE
  # ========================================

  desc "Build + submit to App Store"
  lane :release do |options|
    ensure_git_branch(branch: 'main') unless ENV['CI']

    sync_certificates

    if options[:version]
      increment_version_number(version_number: options[:version])
    end

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1
    )

    test unless options[:skip_tests]

    build_production

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: !options[:skip_review],
      automatic_release: options[:auto_release] || false,
      force: true,
      skip_metadata: options[:skip_metadata] || false,
      skip_screenshots: options[:skip_screenshots] || false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      app_review_information: {
        demo_user: "atabeth",
        demo_password: "pD5p1ir9uxLUf2X2FpNE",
        notes: "Use these credentials to log in and test all features: messaging, social feed, stories, voice/video calls, and translation."
      }
    )

    version = get_version_number(xcodeproj: "Meeshy.xcodeproj")
    UI.success("Version #{version} submitted to App Store!")
  end

  # ========================================
  # UTILITIES
  # ========================================

  desc "Bump version (patch/minor/major)"
  lane :bump_version do |options|
    type = options[:type] || "patch"
    increment_version_number(bump_type: type)
    version = get_version_number(xcodeproj: "Meeshy.xcodeproj")
    UI.success("Version bumped to #{version}")
  end

  desc "Force regenerate all provisioning profiles"
  lane :force_sync do
    match(
      type: "appstore",
      app_identifier: [
        "me.meeshy.app",
        "me.meeshy.app.notification-service",
        "me.meeshy.app.widgets"
      ],
      api_key: api_key,
      force: true,
      force_legacy_encryption: true
    )
  end

  desc "Clean build artifacts"
  lane :clean do
    clear_derived_data
    sh("rm -rf ../build")
  end

  # ========================================
  # ERROR HANDLING
  # ========================================

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception}")
  end
end
