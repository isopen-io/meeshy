# Fastfile for Meeshy iOS
# Uses App Store Connect API Key for all operations (no Apple ID needed)

default_platform(:ios)

platform :ios do
  # ========================================
  # API KEY HELPER
  # ========================================

  def api_key
    @api_key ||= app_store_connect_api_key(
      key_id: require_env("ASC_KEY_ID"),
      issuer_id: require_env("ASC_ISSUER_ID"),
      key_content: ENV["ASC_KEY_CONTENT"],       # Base64 .p8 content (CI)
      key_filepath: ENV["ASC_KEY_FILEPATH"],      # OR path to .p8 file (local dev)
      in_house: false,
      is_key_content_base64: ENV["ASC_KEY_CONTENT"] ? true : false
    )
  end

  # ENV helpers — fail fast rather than silently submitting placeholders.
  # Every secret lives in CI secrets or developer-local env; nothing is committed.
  # See fastlane/SECRETS.md for the full list.

  def require_env(name)
    value = ENV[name]
    if value.nil? || value.strip.empty?
      UI.user_error!("Missing required environment variable: #{name}. See apps/ios/fastlane/SECRETS.md")
    end
    value
  end

  # App Review demo account.
  #
  # Local dev: populate `apps/ios/fastlane/.env` (gitignored). The dotenv gem
  # bundled with fastlane auto-loads that file when fastlane runs from this
  # directory, so DEMO_USER / DEMO_PASSWORD show up as ENV.
  # CI: GitHub Actions injects DEMO_USER / DEMO_PASSWORD as secrets (see
  # .github/workflows/ios-release.yml).
  # Either way, the `release` lane refuses to ship a build without them.
  def app_review_credentials
    {
      demo_user: require_env("DEMO_USER"),
      demo_password: require_env("DEMO_PASSWORD"),
      notes: ENV["DEMO_REVIEW_NOTES"] ||
             "Use these credentials to log in and test all features: messaging, social feed, stories, voice/video calls, and translation."
    }
  end

  # ========================================
  # BEFORE ALL
  # ========================================
  before_all do
    ensure_git_status_clean unless ENV['CI'] || ENV['SKIP_GIT_CHECK']
  end

  # ========================================
  # TESTING
  # ========================================

  desc "Run unit tests"
  lane :test do
    # clean: false is REQUIRED, not an optimization. `clean: true` makes scan run
    # `clean build test` in a SINGLE xcodebuild invocation, which races the Swift
    # const-extraction protocol-list generation (App Intents / MeeshyIntents)
    # against SwiftEmitModule. The compiler then reads a half-written
    # <Target>_const_extract_protocols.json → "Corrupted JSON: unexpected end of
    # file" → the test BUILD fails before a single test runs. Keep clean and build
    # in separate xcodebuild invocations: run `fastlane clean` (or `meeshy.sh
    # clean`) when a pristine slate is genuinely needed. build_production uses
    # clean: false for the same reason.
    scan(
      project: "Meeshy.xcodeproj",
      scheme: "Meeshy",
      configuration: "Debug",
      devices: ["iPhone 16 Pro"],
      code_coverage: true,
      output_directory: "./fastlane/test_output",
      output_types: "html,junit",
      clean: false
    )
  end

  # ========================================
  # CODE SIGNING (Match + API Key)
  # ========================================

  desc "Sync certificates and provisioning profiles"
  lane :sync_certificates do
    match(
      type: "appstore",
      app_identifier: [
        "me.meeshy.app",
        "me.meeshy.app.notification-service",
        "me.meeshy.app.widgets"
      ],
      api_key: api_key,
      readonly: is_ci,
      force_legacy_encryption: true
    )
  end

  desc "Sync development certificates"
  lane :sync_dev_certificates do
    match(
      type: "development",
      app_identifier: "me.meeshy.app",
      api_key: api_key,
      readonly: is_ci
    )
  end

  # ========================================
  # BUILD
  # ========================================

  desc "Build production IPA"
  lane :build_production do
    archive_path = File.expand_path("../build/Meeshy.xcarchive", __dir__)

    # Pass 1 — archive only. Automatic signing falls back to 'Apple Development'
    # for the SPM-bundled binary frameworks (Firebase, GoogleAppMeasurement, …)
    # which would fail App Store Connect's ITMS-90035 analyzer. We accept that
    # here, then strip + re-sign before export below.
    build_app(
      project: "Meeshy.xcodeproj",
      scheme: "Meeshy",
      configuration: "Release",
      output_directory: "./build",
      output_name: "Meeshy.ipa",
      derived_data_path: "./Build",
      clean: false,
      cloned_source_packages_path: "./SourcePackages",
      archive_path: archive_path,
      skip_package_ipa: true,
      xcargs: "DEVELOPMENT_TEAM=D72UK7R5RE -allowProvisioningUpdates SWIFT_OPTIMIZATION_LEVEL=-Onone CODE_SIGN_STYLE=Automatic"
    )

    # Strip embedded framework signatures so the export step re-signs them
    # cleanly with the Apple Distribution cert. Same logic Xcode Cloud's
    # ci_post_xcodebuild.sh applies — keeps ITMS-90035 ('Invalid Signature
    # on Firebase/Google frameworks') from rejecting the upload.
    sh(
      "CI_ARCHIVE_PATH=#{archive_path.shellescape} " \
      "CI_XCODEBUILD_ACTION=archive " \
      "../ci_scripts/ci_post_xcodebuild.sh"
    )

    # Pass 2 — export the (now stripped) archive. ExportOptions.plist has
    # signingStyle=automatic so xcodebuild fetches the Distribution cert
    # and signs the parent app + the stripped embedded frameworks fresh.
    build_app(
      project: "Meeshy.xcodeproj",
      scheme: "Meeshy",
      configuration: "Release",
      output_directory: "./build",
      output_name: "Meeshy.ipa",
      derived_data_path: "./Build",
      cloned_source_packages_path: "./SourcePackages",
      archive_path: archive_path,
      skip_build_archive: true,
      export_options: "./fastlane/ExportOptions.plist"
    )
  end


  # ========================================
  # DEPLOY: TESTFLIGHT
  # ========================================

  desc "Build + upload to TestFlight"
  lane :beta do |options|
    sync_certificates

    # Build number = max(version locale du projet, dernier build connu d'Apple) + 1.
    # latest_testflight_build_number seul sous-compte un build encore en PROCESSING
    # (ou passe Invalid) : il renvoyait alors le numero deja uploade, qu'on
    # re-tentait a l'identique -> 409 ENTITY_ERROR.ATTRIBUTE.INVALID.DUPLICATE
    # ("bundle version must be higher than the previously uploaded version").
    # Prendre le max avec le numero local garantit un build strictement superieur.
    next_build = [
      get_build_number(xcodeproj: "Meeshy.xcodeproj").to_i,
      latest_testflight_build_number(api_key: api_key, initial_build_number: 0).to_i
    ].max + 1
    increment_build_number(build_number: next_build)

    test unless options[:skip_tests]

    build_production

    # On ATTEND la fin du processing Apple (synchronisation / remontee du build
    # dans App Store Connect) avant de rendre la main : skip_waiting_for_build_processing
    # repasse a false. On NE passe toujours PAS de `changelog` ici -- combine a
    # l'attente, pilot resterait bloque a ecrire le changelog si le processing
    # stagne (attente quasi infinie). Sans changelog, l'action attend uniquement
    # que le build soit traite puis rend la main. Le « What to Test » se regle dans
    # App Store Connect, ou via le lane `release` pour les soumissions App Store.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: false
    )

    UI.success("Build uploaded to TestFlight!")
  end

  # ========================================
  # DEPLOY: APP STORE
  # ========================================

  desc "Build + submit to App Store"
  lane :release do |options|
    ensure_git_branch(branch: 'main') unless ENV['CI']

    sync_certificates

    if options[:version]
      increment_version_number(version_number: options[:version])
    end

    # Build number = max(version locale du projet, dernier build connu d'Apple) + 1.
    # latest_testflight_build_number seul sous-compte un build encore en PROCESSING
    # (ou passe Invalid) : il renvoyait alors le numero deja uploade, qu'on
    # re-tentait a l'identique -> 409 ENTITY_ERROR.ATTRIBUTE.INVALID.DUPLICATE
    # ("bundle version must be higher than the previously uploaded version").
    # Prendre le max avec le numero local garantit un build strictement superieur.
    next_build = [
      get_build_number(xcodeproj: "Meeshy.xcodeproj").to_i,
      latest_testflight_build_number(api_key: api_key, initial_build_number: 0).to_i
    ].max + 1
    increment_build_number(build_number: next_build)

    test unless options[:skip_tests]

    build_production

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: !options[:skip_review],
      automatic_release: options[:auto_release] || false,
      force: true,
      skip_metadata: options[:skip_metadata] || false,
      skip_screenshots: options[:skip_screenshots] || false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      app_review_information: app_review_credentials
    )

    version = get_version_number(xcodeproj: "Meeshy.xcodeproj")
    UI.success("Version #{version} submitted to App Store!")
  end

  # ========================================
  # UTILITIES
  # ========================================

  desc "Bump version (patch/minor/major)"
  lane :bump_version do |options|
    type = options[:type] || "patch"
    increment_version_number(bump_type: type)
    version = get_version_number(xcodeproj: "Meeshy.xcodeproj")
    UI.success("Version bumped to #{version}")
  end

  desc "Force regenerate all provisioning profiles"
  lane :force_sync do
    match(
      type: "appstore",
      app_identifier: [
        "me.meeshy.app",
        "me.meeshy.app.notification-service",
        "me.meeshy.app.widgets"
      ],
      api_key: api_key,
      force: true,
      force_legacy_encryption: true
    )
  end

  desc "Clean build artifacts"
  lane :clean do
    clear_derived_data
    sh("rm -rf ../build")
  end

  # ========================================
  # ERROR HANDLING
  # ========================================

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception}")
  end
end
