# Appfile for Meeshy iOS
# Uses App Store Connect API Key (not Apple ID) for CI/CD

app_identifier("me.meeshy.app")

# Team ID (Apple Developer Portal)
team_id(ENV["FASTLANE_TEAM_ID"] || "D72UK7R5RE")

# App Store Connect Team ID
itc_team_id(ENV["FASTLANE_ITC_TEAM_ID"] || ENV["FASTLANE_TEAM_ID"] || "YOUR_TEAM_ID")

# Per-lane bundle IDs
for_platform :ios do
  for_lane :beta do
    app_identifier("me.meeshy.app")
  end

  for_lane :release do
    app_identifier("me.meeshy.app")
  end
end
