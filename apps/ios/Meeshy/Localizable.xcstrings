    "Enregistrez votre voix pour activer le clonage vocal personnalise. Vos messages audio traduits garderont votre voix naturelle." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nehmen Sie Ihre Stimme auf, um das personalisierte Stimmklonen zu aktivieren. Ihre übersetzten Audionachrichten behalten Ihre natürliche Stimme."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Record your voice to enable personalized voice cloning. Your translated audio messages will keep your natural voice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Graba tu voz para activar la clonación vocal personalizada. Tus mensajes de audio traducidos conservarán tu voz natural."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grave sua voz para ativar a clonagem vocal personalizada. Suas mensagens de áudio traduzidas manterão sua voz natural."
          }
        }
      }
    },
