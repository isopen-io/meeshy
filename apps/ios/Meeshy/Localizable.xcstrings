      }
    },
    "Meeshy est une plateforme de messagerie en temps reel haute performance avec traduction multilingue, clonage vocal et chiffrement de bout en bout.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy is a high-performance real-time messaging platform with multilingual translation, voice cloning, and end-to-end encryption."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy ist eine leistungsstarke Echtzeit-Messaging-Plattform mit mehrsprachiger Übersetzung, Stimmklonen und Ende-zu-Ende-Verschlüsselung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy es una plataforma de mensajería en tiempo real de alto rendimiento con traducción multilingüe, clonación vocal y cifrado de extremo a extremo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy é uma plataforma de mensagens em tempo real de alto desempenho com tradução multilíngue, clonagem vocal e criptografia de ponta a ponta."
          }
        }
      }
    },
    "Meeshy utilise les bibliotheques open source suivantes.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeshy uses the following open source libraries."
