    "onboarding.page1.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Triff Menschen über deine Grenzen hinaus — Frankreich, Senegal, Brasilien, Japan, Australien, Kanada… jeder liest in seiner Sprache, auf allen 5 Kontinenten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meet people beyond your borders — France, Senegal, Brazil, Japan, Australia, Canada… everyone reads in their own language, across all 5 continents"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conoce a personas más allá de tus fronteras — Francia, Senegal, Brasil, Japón, Australia, Canadá… cada uno lee en su idioma, en los 5 continentes"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rencontrez des personnes au-delà de vos frontières — France, Sénégal, Brésil, Japon, Australie, Canada… chacun lit dans sa langue, sur les 5 continents"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conheça pessoas além das suas fronteiras — França, Senegal, Brasil, Japão, Austrália, Canadá… cada um lê no seu idioma, nos 5 continentes"
          }
        }
      }
    },
